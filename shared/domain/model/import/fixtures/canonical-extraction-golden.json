  "lyricVariants": [
    {
      "language": "sa",
      "script": "devanagari",
      "sections": [
        {
          "sectionOrder": 1,
          "text": "वातापि गणपतिं भजेऽहं वारणास्यं वरप्रदं श्री"
        },
        {
          "sectionOrder": 2,
          "text": "भूतादि संसेवित चरणं भूत भौतिक प्रपञ्च भरणं"
        },
        {
          "sectionOrder": 3,
          "text": "वीतरागिणं विनत योगिनं विश्वकारणं विघ्नवारणं"
        },
        {
          "sectionOrder": 4,
          "text": "पुरा कुम्भ सम्भव मुनिवर प्रपूजितं त्रिकोण मध्यगतं"
        }
      ]
    },
    {
      "language": "en",
      "script": "latin",
      "sections": [
        {
          "sectionOrder": 1,
          "text": "vAtApi gaNapatiM bhajE'haM vAraNAsyaM varapradaM shrI"
        },
        {
          "sectionOrder": 2,
          "text": "bhUtAdi saMsEvita caraNaM bhUta bhautika prapanca bharaNaM"
        },
        {
          "sectionOrder": 3,
          "text": "vItarAgiNaM vinata yOginaM vishvakAraNaM vighnavAraNaM"
        },
        {
          "sectionOrder": 4,
          "text": "purA kumbha sambhava munivara prapUjitaM trikONa madhyagataM"
        }
      ]
    }
  ],
